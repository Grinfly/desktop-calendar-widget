{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "蚕豆",
  "version": "0.1.1",
  "identifier": "com.grinf.desktop-calendar-widget",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "蚕豆",
        "width": 300,
        "height": 360,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "minWidth": 260,
        "minHeight": 300,
        "maxWidth": 640,
        "maxHeight": 720,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
